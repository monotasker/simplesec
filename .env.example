# SimpleSec Environment Configuration
#
# Copy this file to .env in the same directory to customize behavior.
# All values are optional - defaults will be used if not set.

# GPG Cache Settings (in seconds)
# Default: 3600 (1 hour) - cache for entire session
GPG_CACHE_TTL=3600
GPG_MAX_CACHE_TTL=7200

# Auto-start gpg-agent? (yes/no)
# Default: yes
AUTO_START_AGENT=yes

# Clear GPG agent cache on logout? (yes/no)
# Default: yes
CLEAR_CACHE_ON_LOGOUT=yes

# GPG Agent config file path (auto-detected if not set)
GPG_AGENT_CONF=""

# Secret store root directory (should match your script's SECRET_ROOT)
SECRET_ROOT="$HOME/.secrets/pass"
