# SimpleSec Environment Configuration
#
# Copy this file to .env in the same directory to customize behavior.
# Process environment variables override values from this file.
# All security checks are fail-closed by default (secure for team use).

# --- File / clipboard -------------------------------------------------------

# Temp credential file lifetime for `file` / template shorthand (seconds).
# This is NOT the GPG unlock cache — see REQUIRE_CACHE_TTL below.
# SIMPLESEC_TTL=120

# Default store label when -s / --store is omitted.
# SIMPLESEC_STORE=default

# --- Security (fail-closed; unset == enforced) ------------------------------

# Require a YubiKey (OpenPGP card identified as YubiKey / visible to ykman).
SIMPLESEC_REQUIRE_YUBIKEY=1

# Maximum allowed gpg-agent cache TTL in seconds (0 = prompt every time for
# software keys; for YubiKey also use LOCK_BEFORE_DECRYPT + unplug when idle).
SIMPLESEC_REQUIRE_CACHE_TTL=0

# Require decrypt private key stubs on the smartcard (not software keys on disk).
SIMPLESEC_REQUIRE_KEY_ON_CARD=1

# Require encrypt/decrypt touch policy On/Fixed/Cached (needs ykman).
SIMPLESEC_REQUIRE_TOUCH=1

# Disconnect smartcard before each decrypt so PIN cache is cleared.
SIMPLESEC_LOCK_BEFORE_DECRYPT=1

# Escape hatch — disables ALL checks (prints a loud warning). Do not set in
# shared team configs.
SIMPLESEC_ALLOW_INSECURE=0

# --- Legacy / optional ------------------------------------------------------

# Older drafts referenced these; prefer SIMPLESEC_* names above.
# GPG_CACHE_TTL=0
# GPG_MAX_CACHE_TTL=0
